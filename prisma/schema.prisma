// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum StatusKawin {
  Kawin
  tidak_kawin @map("Tidak Kawin")
}

enum StatusPegawai {
  Aktif
  Nonaktif
}

model MasterData {
  id   Int     @id @default(autoincrement())
  nama String? @db.VarChar(100)
  tipe String? @db.VarChar(50)

  pegawai_jabatan Pegawai[] @relation("PegawaiJabatan")
  pegawai_departemen Pegawai[] @relation("PegawaiDepartemen")

  @@map("master_data")
}

model MasterWilayah {
  id        Int     @id @default(autoincrement())
  kecamatan String? @db.VarChar(100)
  kabupaten String? @db.VarChar(100)
  provinsi  String? @db.VarChar(100)

  pegawai_kecamatan Pegawai[]

  @@map("master_wilayah")
}

model Pegawai {
  id Int @id @default(autoincrement())
  foto_pegawai String? @db.VarChar(255)
  nip String? @unique @db.VarChar(30)
  nama_pegawai String? @db.VarChar(255)
  email String? @unique @db.VarChar(255)
  nomor_hp String? @db.VarChar(20)
  tempat_lahir String? @db.VarChar(100)
  id_kecamatan Int?
  alamat_lengkap String? @db.Text
  jarak_rumah_kantor Int? @db.TinyInt
  tanggal_lahir DateTime? @db.Date
  status_kawin StatusKawin?
  jumlah_anak Int? @default(0) @db.TinyInt
  tanggal_masuk DateTime? @db.Date
  id_jabatan Int?
  id_departemen Int?
  usia Int?
  status StatusPegawai? @default(Aktif)
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt

  jabatan MasterData? @relation("PegawaiJabatan", fields: [id_jabatan], references: [id], onDelete: Cascade, onUpdate: Cascade)
  departemen MasterData? @relation("PegawaiDepartemen", fields: [id_departemen], references: [id], onDelete: Cascade, onUpdate: Cascade)
  kecamatan MasterWilayah? @relation(fields: [id_kecamatan], references: [id], onDelete: Cascade, onUpdate: Cascade)

  pendidikan PegawaiPendidikan[]
  user User[]
  tunjangan DetailTunjangan[]

  @@map("pegawai")
}

model PegawaiPendidikan {
  id Int @id @default(autoincrement())
  id_pegawai Int?
  tingkat_pendidikan String? @db.VarChar(50)
  nama_sekolah String? @db.VarChar(255)
  tahun_lulus Int?

  pegawai Pegawai? @relation(fields: [id_pegawai], references: [id], onDelete: Cascade, onUpdate: Cascade)
  
  @@map("pegawai_pendidikan")
}

model UserRole {
  id Int @id @default(autoincrement())
  nama_role String? @db.VarChar(100)
  created_at DateTime? @default(now())

  permission RolePermission[]
  user User[]

  @@map("user_role")
}

enum permission {
  All
  Own
  No
}

model RolePermission {
  id Int @id @default(autoincrement())
  id_role Int?
  modul_fitur String? @db.VarChar(100)
  akses Int? @db.TinyInt
  create Int? @db.TinyInt
  read permission @default(No)
  update permission @default(No)
  delete permission @default(No)

  role UserRole? @relation(fields: [id_role], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("role_permission")
}

model User {
  id Int @id @default(autoincrement())
  id_role Int?
  id_pegawai Int?
  username String? @unique @db.VarChar(100)
  password_hash String? @db.VarChar(255)
  nama String? @db.VarChar(255)
  email String? @db.VarChar(255)
  last_session String? @db.VarChar(255)
  last_login DateTime? @db.Timestamp()
  updated_at DateTime? @updatedAt
  created_at DateTime? @default(now())
  disabled Int? @default(0) @db.TinyInt

  role UserRole? @relation(fields: [id_role], references: [id], onDelete: Cascade, onUpdate: Cascade)
  pegawai Pegawai? @relation(fields: [id_pegawai], references: [id], onDelete: Cascade, onUpdate: Cascade)

  activities_created Activities[] @relation("ActivitiesCreated")
  activities_updated Activities[] @relation("ActivitiesUpdated")

  @@map("user")
}

model Activities {
  id BigInt @id @default(autoincrement())
  title String? @db.VarChar(255)
  content String? @db.Text
  ua String? @db.VarChar(256)
  ip String? @db.VarChar(64)
  url String? @db.Text
  browser String? @db.VarChar(64)
  platform String? @db.VarChar(64)
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt
  created_by Int?
  updated_by Int?

  activities_created User? @relation("ActivitiesCreated", fields: [created_by], references: [id], onDelete: SetNull)
  activities_updated User? @relation("ActivitiesUpdated", fields: [updated_by], references: [id], onDelete: SetNull)

  @@map("activities")
}

model SettingTunjangan {
  id              Int       @id @default(autoincrement())
  tarif_per_km    Decimal   @db.Decimal(10, 2) // Menggunakan Decimal untuk nominal uang
  berlaku_mulai   DateTime  @db.Date
  min_kilometer   Int
  max_kilometer   Int
  created_at      DateTime? @default(now())
  updated_at      DateTime? @updatedAt

  @@map("setting_tunjangan_transport")
}

model TunjanganBulan {
  id              Int       @id @default(autoincrement())
  bulan           Int       // Menyimpan angka bulan (1-12)
  tahun           Int       // Menyimpan angka tahun (Misal: 2026)
  total_penerima  Int       @default(0)
  total_tunjangan Decimal   @default(0) @db.Decimal(15, 2) // Total bisa besar, misal milyaran
  created_at      DateTime? @default(now())
  updated_at      DateTime? @updatedAt

  detail_tunjangan DetailTunjangan[]

  @@map("tunjangan_transport")
}

model DetailTunjangan {
  id              Int       @id @default(autoincrement())
  id_tunjangan    Int
  id_pegawai      Int
  kilometer       Int       // Bisa Int karena aturan soal bilang dibulatkan
  jumlah_hari     Int       
  nominal         Decimal   @db.Decimal(10, 2) // Nominal per pegawai

  tunjangan       TunjanganBulan @relation(fields: [id_tunjangan], references: [id], onDelete: Cascade)
  pegawai         Pegawai        @relation(fields: [id_pegawai], references: [id], onDelete: Cascade)

  @@map("detail_tunjangan_transport")
}